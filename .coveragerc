# Coverage measurement config — keeps local and CI runs on the same footing.
# Source roots mirror the --cov flags in .github/workflows/test.yml.
[run]
# Branch coverage on (P6, 2026-07-02): statement coverage alone hid a 5+pp gap
# of executed-but-never-forked branches (error/degradation paths). The gate in
# test.yml stays at 85 — this makes the dial honest, it does not tighten it.
branch = True
source =
    scripts
    projects/news/scripts
    projects/wiki/scripts
omit =
    tests/*
    */__pycache__/*
    */tests/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
