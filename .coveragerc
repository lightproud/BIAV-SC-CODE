# Coverage measurement config — keeps local and CI runs on the same footing.
# Source roots mirror the --cov flags in .github/workflows/test.yml.
[run]
# Branch coverage on (P6, 2026-07-02): statement coverage alone hid a 5+pp gap
# of executed-but-never-forked branches (error/degradation paths). This makes
# the dial honest, it does not tighten it (the gate lives in test.yml — 92
# since the 2026-07-11 gap-fill sweep).
branch = True
source =
    scripts
    projects/news/scripts
    projects/wiki/scripts
omit =
    tests/*
    */__pycache__/*
    */tests/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
