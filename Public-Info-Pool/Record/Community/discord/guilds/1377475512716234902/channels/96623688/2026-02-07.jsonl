{"id": "1469583522325856299", "channel_id": "1391701560496623688", "author_id": "1155282626668662816", "author_name": "ya.ma.00", "content": "", "timestamp": "2026-02-07T06:40:15.264000+00:00", "attachments": [{"id": "1469583522451689512", "filename": "IMG_0573.png", "content_type": "image/jpeg", "size": 625925, "url": "https://cdn.discordapp.com/attachments/1391701560496623688/1469583522451689512/IMG_0573.png?ex=6a343b8f&is=6a32ea0f&hm=37b565bcb28dca85b82812ff4288ea2aa1379fcb291fe7db2f7797f762e08f6f&"}, {"id": "1469583522791690441", "filename": "IMG_0572.png", "content_type": "image/jpeg", "size": 665104, "url": "https://cdn.discordapp.com/attachments/1391701560496623688/1469583522791690441/IMG_0572.png?ex=6a343b8f&is=6a32ea0f&hm=8c551315f5ec7f932ff5c52e03f44660b210db316bfda7697adc4145d6cedccb&"}]}
