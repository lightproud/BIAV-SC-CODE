{"id": "1491774138925318228", "channel_id": "1391701560496623688", "type": 0, "author_id": "516998769888329749", "author_name": "zzzorz", "author_bot": false, "content": "シレスト餅あたりは、トゥルー餅を持っていれば使わないかな…", "timestamp": "2026-04-09T12:17:50.543000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
