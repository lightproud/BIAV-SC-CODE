{"id": "1491733074499600455", "channel_id": "1391701560496623688", "type": 0, "author_id": "1410178662933987368", "author_name": "satansukisuki", "author_bot": false, "content": "恒常、イベント札で砕いて良さげなものってありますか？", "timestamp": "2026-04-09T09:34:40.021000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
