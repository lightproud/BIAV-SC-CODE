{"id": "1408140948420165632", "channel_id": "1408140948420165632", "type": 0, "author_id": "170997565385342976", "author_name": "notsoshrimpleofficial", "author_bot": false, "content": "I was seeking these as I have claimed them in Current Workloads as one does;\n\nand yet, I cannot find them. \n\nHelp! Are they here?", "timestamp": "2025-08-21T17:29:24.097000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1408140948420165632", "flags": 0, "thread_title": "awakener lines in general (profile stories/quotes/voicelines)", "forum_channel_id": "1404748432328888401", "thread_tags": ["1410391772894330961", "1404748570871201913", "1412867203514236942"], "is_thread_starter": true}
