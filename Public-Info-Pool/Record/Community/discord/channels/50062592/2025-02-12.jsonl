{"id": "1339255805412638733", "channel_id": "1300659495550062592", "type": 0, "author_id": "145502316647153664", "author_name": "banadil", "author_bot": false, "content": "이거, 진짜 중요합니다.", "timestamp": "2025-02-12T15:24:26.180000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
{"id": "1339255945540272251", "channel_id": "1300659495550062592", "type": 0, "author_id": "145502316647153664", "author_name": "banadil", "author_bot": false, "content": "광기 0일때 저걸 쓰면 30점 회복하고, 1회 더 30점 회복.", "timestamp": "2025-02-12T15:24:59.589000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
