{"id": "1426999977342931117", "channel_id": "1326453691527594035", "type": 0, "author_id": "120677325137379328", "author_name": "crimsondream24", "author_bot": false, "content": "This is just my opinion but I don't think Erica is very good without another Para character on the team. I also don't like Doresain in the second slot because that means he dies after Erica and then you have basically no damage left.", "timestamp": "2025-10-12T18:28:26.976000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
