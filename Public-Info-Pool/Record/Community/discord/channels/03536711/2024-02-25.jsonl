{"id": "1211151784404582550", "channel_id": "1173463482503536711", "type": 0, "author_id": "387191775183241216", "author_name": "kervin_joshua", "author_bot": false, "content": "菲茵特說老實的也是紫藍色系", "timestamp": "2024-02-25T03:24:47.514000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
