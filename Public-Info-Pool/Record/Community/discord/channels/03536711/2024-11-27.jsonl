{"id": "1311267274476359743", "channel_id": "1173463482503536711", "type": 0, "author_id": "944524613168279553", "author_name": "ena04564", "author_bot": false, "content": "講真米粒屬於那種，信佛教但是信的不是正統那種佛教，是偏邪教性質的但自己不知道", "timestamp": "2024-11-27T09:48:00.403000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
