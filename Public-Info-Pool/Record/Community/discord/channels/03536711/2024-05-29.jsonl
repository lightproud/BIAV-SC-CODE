{"id": "1245253369069568011", "channel_id": "1173463482503536711", "author_id": "290860304697655296", "author_name": "cerberusc", "content": "<:nomoney:1243502188471517235>", "timestamp": "2024-05-29T05:52:18.875000+00:00"}
