{"id": "1351014211442053121", "channel_id": "1300659718653476925", "type": 0, "author_id": "208469443703996426", "author_name": "smauguerino", "author_bot": false, "content": "Boa noite galera, tranquilo? \nComecei a jogar a poucas horas o jogo e queria saber se alguém tem alguma dica para novatos. Personagens e afins para f2p.", "timestamp": "2025-03-17T02:08:08.638000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
