{"id": "1517239623028445255", "channel_id": "1300659718653476925", "type": 0, "author_id": "1247682399513612392", "author_name": "lordfelipe0827_59720", "author_bot": false, "content": "Mas tirando pontos específicos, temos bem pouco sobre ela, até a GDoll que é literalmente uma Doll alternativa tem mais destaque", "timestamp": "2026-06-18T18:48:35.079000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
