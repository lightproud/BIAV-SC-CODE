{"id": "1209394009055952946", "channel_id": "1170692781216378960", "type": 0, "author_id": "543093645947961348", "author_name": "turboseer", "author_bot": false, "content": "So if you had 5 copies of the characater, if you delete it you get 5 selectors. \nIf you dont wish to delete the character you get 4 copies instead.", "timestamp": "2024-02-20T07:00:01.213000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
