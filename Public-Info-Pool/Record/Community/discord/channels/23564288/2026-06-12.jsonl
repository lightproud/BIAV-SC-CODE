{"id": "1514993384194969680", "channel_id": "1514993384194969680", "type": 0, "author_id": "1121722385243066448", "author_name": "shunia3055", "author_bot": false, "content": "右上增加一个取消按钮", "timestamp": "2026-06-12T14:02:50.008000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1514993384194969680", "flags": 0, "thread_title": "每回合第二次使用钥令时可以在选择界面回退", "forum_channel_id": "1180845276823564288", "thread_tags": ["1181168158678204497"], "is_thread_starter": true}
