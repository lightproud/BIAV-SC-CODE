{"id": "1349684734590193736", "channel_id": "1300659436804640788", "author_id": "239474863570419712", "author_name": "applepieeater123", "content": "彫刻はカードに追加エフェクトです", "timestamp": "2025-03-13T10:05:16.656000+00:00"}
