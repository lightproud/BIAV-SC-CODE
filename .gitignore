# global_collectors runtime output (if run standalone)
projects/news/data/collected_raw.json
morimens_extract.zip

# one-off reverse-engineering tooling (local-only, hardcoded local paths)
_frida_hook_v2.py
_run_hook_v2.bat

# media cache (downloaded images/covers, archived to GitHub Releases)
projects/news/data/media/*.jpg
projects/news/data/media/*.jpeg
projects/news/data/media/*.png
projects/news/data/media/*.gif
projects/news/data/media/*.webp
projects/news/data/media/*.avif
projects/news/data/media/*.mp4
projects/news/data/media/*.webm
projects/news/data/media/*.tar.gz

# auto-generated indexes (rebuilt by dream.py / memory_search.py)
# vectors.json.gz is committed (compressed, ~3MB) so new sessions have instant search
assets/data/vectors.json
assets/data/semantic-index.json
assets/data/knowledge-graph.json
assets/data/memory-utility.json
assets/data/precomputed-cache.json
projects/news/output/alerts.json

# session digests — only .md conversation records are committed;
# .json metadata and .jsonl progress logs stay local (no longer generated in v0.3)
memory/session-digests/*.json
# .progress.jsonl 实时累积日志，每个 PostToolUse 追加，导致 stop hook
# 误报循环（守密人 2026-04-26 裁定排除）。保留物理文件作过程追溯，
# 但不入 git，避免反复 commit 噪音。
memory/session-digests/*.jsonl
memory/session-digests/*.progress.jsonl

# frida hook 逆向工具临时产出（extracted_lua/ 下已入库的文件不受影响）
extracted_lua/hook_capture/
extracted_lua/plaintext_from_memory/

# 补录媒体二进制走 Releases（决策038），git 只留 manifest
projects/news/data/media/files/
projects/news/data/media/*.tar
