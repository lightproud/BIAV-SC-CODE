{"id": "1447174617599971391", "channel_id": "1326453691527594035", "type": 19, "author_id": "289320818901778434", "author_name": "nikolazuli", "author_bot": false, "content": "all pvp cards in hand are arranged according to their on field position. so if you see your opponent play their leftmost card (your right) it usually corresponds to their frontmost unit", "timestamp": "2025-12-07T10:35:16.040000+00:00", "edited_timestamp": "2025-12-07T10:37:23.266000+00:00", "pinned": false, "mentions": ["857272938817388564"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1447174238875160668", "has_thread": false, "thread_id": null, "flags": 0}
