{"id": "1352955413221343262", "channel_id": "1300659580446969918", "type": 0, "author_id": "1341353800459485247", "author_name": "somethingno1fan", "author_bot": false, "content": "И че прям 1-8 закрыл и 10 ивентовых вываливают?По-любому че-то делать надо)", "timestamp": "2025-03-22T10:41:47.208000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
