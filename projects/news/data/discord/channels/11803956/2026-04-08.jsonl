{"id": "1491301607479054366", "channel_id": "1491194430110044340", "type": 0, "author_id": "596922317142228992", "author_name": "juuki0811", "author_bot": false, "content": "Mist sequence is the gacha game where Mouchette came from\nAnd it already ended its service (EOS) \nThat's why they were able to get Mouchette as a limited character permanently added to the game\nSo they can rerun her anytime", "timestamp": "2026-04-08T05:00:10.267000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1491194430110044340", "flags": 0, "thread_title": "1 Week Account Pulling Advice?", "forum_channel_id": "1356200968311803956", "thread_tags": ["1400747088995811358"]}
