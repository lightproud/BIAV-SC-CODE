{"id": "1427428913201680466", "channel_id": "1400749543288475770", "type": 19, "author_id": "50222389287452672", "author_name": "flinx", "author_bot": false, "content": "it's really difficult to use Tawil at E0 especially without her proper team mates. You need someone that can cycle the deck fast or draw her cards for you to do your combos. You need Ryker and/or Hameln to use her cards properly. If you don't, your cards will get stuck in the deck and no chance to cycle them", "timestamp": "2025-10-13T22:52:53.254000+00:00", "edited_timestamp": "2025-10-13T22:53:14.583000+00:00", "pinned": false, "mentions": ["505480361489465355"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1427419297982185634", "has_thread": false, "thread_id": null, "flags": 0}
