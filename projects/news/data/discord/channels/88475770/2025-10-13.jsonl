{"id": "1427436619484499968", "channel_id": "1400749543288475770", "type": 19, "author_id": "693983290423509042", "author_name": "climbkaly", "author_bot": false, "content": "Sorel likes 1 blue unit on the team. \n\nIdeally its Celeste, Tulu, Corposant or Caecus. But you don't have any of them. So Goliath.", "timestamp": "2025-10-13T23:23:30.575000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["457756449884340225"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1427436401494069309", "has_thread": false, "thread_id": null, "flags": 0}
