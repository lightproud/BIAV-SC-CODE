{"id": "1431718816223592470", "channel_id": "1400749543288475770", "type": 19, "author_id": "393585313618067456", "author_name": "katesthio", "author_bot": false, "content": "Reading the Awakeners, WoDs, Covenants are the best guide <:slick:1356053160531198064>", "timestamp": "2025-10-25T18:59:25.837000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["1151477474815901716"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1431640381543420018", "has_thread": false, "thread_id": null, "flags": 0}
{"id": "1431719461584371775", "channel_id": "1400749543288475770", "type": 19, "author_id": "393585313618067456", "author_name": "katesthio", "author_bot": false, "content": "I agree with Omena. That is currently your best team, and should be able to beat chapter 6. The fault might lay in the Lvls on your Awakeners or Skill Lvls. If you’re still struggling, might be a mechanic you’re not understanding, or optimizing choices.", "timestamp": "2025-10-25T19:01:59.703000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["133096352266715136"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1431715076942856342", "has_thread": false, "thread_id": null, "flags": 0}
