{"id": "1431463430086463488", "channel_id": "1400749543288475770", "type": 0, "author_id": "152232899624566784", "author_name": ".kyuubey", "author_bot": false, "content": "new player here. should I replace ramona with one of these?", "timestamp": "2025-10-25T02:04:37.037000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [{"id": "1431463429830344835", "filename": "image.png", "content_type": "image/png", "size": 1393153, "url": "https://cdn.discordapp.com/attachments/1400749543288475770/1431463429830344835/image.png?ex=6a35f534&is=6a34a3b4&hm=55e6d0aec6a0e1710f0e85e804ce922aced1cb1df86681f7bbe5be59de4eb0bd&"}], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
{"id": "1431508789064110101", "channel_id": "1400749543288475770", "type": 19, "author_id": "393585313618067456", "author_name": "katesthio", "author_bot": false, "content": "Caecus(Counter, Shielder, Tentacle Dmg Stacker, On Demand-Vuln Application, Healer)\n\nRamona(Silver Key, Card Find w/ making it 0 cost + 1 Insight)\n\nNautila(Shielder, Counter)\n\nGoliath(Strength Gen, Tentacle Dmg Gen, Extra Attacks Gen, Strength Scaler)", "timestamp": "2025-10-25T05:04:51.460000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["152232899624566784"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1431463430086463488", "has_thread": false, "thread_id": null, "flags": 0}
