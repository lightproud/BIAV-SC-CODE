{"id": "1497871224641028196", "channel_id": "1400749543288475770", "type": 0, "author_id": "191966381640646656", "author_name": "krausser", "author_bot": false, "content": "deemed the utility of GRamona a bit better for me than crit from Tinct, but I'd imagine these's an argument for either", "timestamp": "2026-04-26T08:05:29.056000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
