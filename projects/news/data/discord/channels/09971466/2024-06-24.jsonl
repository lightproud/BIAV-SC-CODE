{"id": "1254717047485763634", "channel_id": "1180850818509971466", "type": 0, "author_id": "372020544494764043", "author_name": "ariate", "author_bot": false, "content": "我要麻毒初見時就因為這樣還不太能控住，而且到輸的時候才知道，啊，莉莉是主C不是控", "timestamp": "2024-06-24T08:37:35.636000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
