{"id": "1459110631608287428", "channel_id": "1300659552701648960", "type": 19, "author_id": "113374123798859776", "author_name": "legendaryredz", "author_bot": false, "content": "Si tu veux remplacer Uvhash spécifiquement \nJe te conseillerai bien Sorel\nElle est monstrueuse avec Thais et Pickman (ses 2 meilleurs supports) dans la même team", "timestamp": "2026-01-09T09:04:43.540000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["781262097375952977"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1459104584558444577", "has_thread": false, "thread_id": null, "flags": 0}
