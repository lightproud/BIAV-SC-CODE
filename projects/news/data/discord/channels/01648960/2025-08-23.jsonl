{"id": "1408741146536181760", "channel_id": "1300659552701648960", "type": 0, "author_id": "233874560682950656", "author_name": "wolfierce", "author_bot": false, "content": "tu verras que les équipes pure ultra contiennent du chaos et qu'il n'y a pas de chaos/ultra. Ça pourrait t'aider à mieux savoir quel effet est actif pour 24", "timestamp": "2025-08-23T09:14:22.479000+00:00", "edited_timestamp": "2025-08-23T09:14:41.725000+00:00", "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
