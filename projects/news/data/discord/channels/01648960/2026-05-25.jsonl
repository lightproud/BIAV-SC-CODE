{"id": "1508423050062991450", "channel_id": "1300659552701648960", "type": 19, "author_id": "216503685369430016", "author_name": ".xarta", "author_bot": false, "content": "elle est broken. \nPleins de stats \n200 de keyflare lorsque tu trigger Annihilation\nElle marche sur pleins de perso, même sur ceux qui en ont rien à faire de la Death Resistance", "timestamp": "2026-05-25T10:54:40.280000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1508395647634641068", "has_thread": false, "thread_id": null, "flags": 0}
