{"id": "1394106271472423054", "channel_id": "1326453763355185215", "type": 19, "author_id": "507989103011168287", "author_name": "nightjar0928", "author_bot": false, "content": "Yeah😂 , the Minecraft server scams I used to get did that all the time.", "timestamp": "2025-07-14T00:00:36.361000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["289320818901778434"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1394105960645263391", "has_thread": false, "thread_id": null, "flags": 0}
