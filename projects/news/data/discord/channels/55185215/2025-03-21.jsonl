{"id": "1352535965360459800", "channel_id": "1326453763355185215", "type": 19, "author_id": "139343733714845697", "author_name": "satachan", "author_bot": false, "content": "No wonder their old game exploded", "timestamp": "2025-03-21T06:55:03.045000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["627111975016464395"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1352405788655620227", "has_thread": false, "thread_id": null, "flags": 0}
