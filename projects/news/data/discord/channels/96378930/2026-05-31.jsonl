{"id": "1510709313449230536", "channel_id": "1510692581120409760", "type": 0, "author_id": "806384001895890965", "author_name": "0.0._.0_0.", "author_bot": false, "content": "畢竟是撿垃圾嘛\n所以帶任意SR或以上的銀鑰 精通即可", "timestamp": "2026-05-31T18:19:27.948000+00:00", "edited_timestamp": "2026-05-31T18:19:35.991000+00:00", "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1510692581120409760", "flags": 0, "thread_title": "AA凱刻斯", "forum_channel_id": "1174179624096378930", "thread_tags": ["1174179755759763526", "1174179716706619494", "1174179700470460447"]}
