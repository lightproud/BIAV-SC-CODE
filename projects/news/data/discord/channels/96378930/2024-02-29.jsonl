29_125924.jpg", "content_type": "image/jpeg", "size": 197099, "url": "https://cdn.discordapp.com/attachments/1212691823869562931/1212691828546076702/Screenshot_20240229_125924.jpg?ex=69fb08c6&is=69f9b746&hm=dc48883a5d7dcefc2d0e02e081381e306fe1619171522416327ec39147de795e&"}, {"id": "1212691829028560956", "filename": "Screenshot_20240229_143322.jpg", "content_type": "image/jpeg", "size": 118575, "url": "https://cdn.discordapp.com/attachments/1212691823869562931/1212691829028560956/Screenshot_20240229_143322.jpg?ex=69fb08c6&is=69f9b746&hm=141004a463b26661ccfbd2e472a4de49853abb82390d480702deeecee8e4eea1&"}], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1212691823869562931", "flags": 0, "thread_title": "融灾三级警报350通关配置心得分享", "forum_channel_id": "1174179624096378930", "is_thread_starter": true, "thread_tags": ["1181143392739147778"]}
{"id": "1212641663122538537", "channel_id": "1212641663122538537", "type": 0, "author_id": "1112189464140324947", "author_name": "timee_ky", "author_bot": false, "content": "大家好我是Timee，是个笨蛋深海玩家，目前因为一直在玩深海并且随着2.29版本更新产出了新的密契，所以写一下自己的心得，如果有不对的地方见谅我也尽可能及时改正。\n\n✨密契简评\n\n海归线小加强之后效果是50+精通/4的触发概率，在boss战中效果翻倍。 若非深海开局可获得装备者12%攻击的力量\n点评：在深海队伍中勉强可用，但是在深海国家队中似乎没太有位置，效果目前看来不算特别特别强力，可以进一步提升道中能力，不过深海精通本身其实并不算强其实不太想堆精通，如果想带海归线可以尝试带暴击等其他词条只用初始给的50概率来白嫖触手伤害或者直接200+精通稳定触发触手效果。由于现在调查行动首通会送灵核70级也不是难事了，角色的攻击力可能会提升的比较高。170点攻击基础的角色能带来21点（取整）的力量，可以算不错的加成了\n\n再演化的效果是探索开始装备者获得35狂气，并且每次狂气爆发后回合结束回复2狂最多堆叠3次\n点评：再演化的35狂气配合神三叠的25狂气即落地60狂，基本测试是没有其他影响一般3回合结束时差一点狂气，4回合满狂这个样子，能较好的解决落地站并且在长线战斗中也有着不错的作用\n\n\n国家队：目前尝试给图鲁 神王再演化，拉蒙娜 指针红拥，珊 珊瑚女海归，墨菲隐秘诞生白子\n\n碎碎念：今天花了大概1300印章洗各种密契，洗练好花费资源，演化也洗了每个披萨2满词条的样子，总之欢迎大家来试用！", "timestamp": "2024-02-29T06:05:02.281000+00:00", "edited_timestamp": "2024-02-29T07:52:30.480000+00:00", "pinned": false, "mentions": [], "reactions": [{"emoji": "🍟", "emoji_id": null, "count": 9}], "attachments": [{"id": "1212641663445377094", "filename": "D0110F52-EF4B-4301-B486-058C5353B7B5.jpg", "content_type": "image/jpeg", "size": 165609, "url": "https://cdn.discordapp.com/attachments/1212641663122538537/1212641663445377094/D0110F52-EF4B-4301-B486-058C5353B7B5.jpg?ex=69fb82ce&is=69fa314e&hm=399c6f79991fbd164cb3fe94f33fd02eaf38840ad7d239e6ada4da4493e24a1e&"}, {"id": "1212641663780917349", "filename": "3343C9C8-7DC3-4D8F-8BDC-FEA30BD5559C.jpg", "content_type": "image/jpeg", "size": 173623, "url": "https://cdn.discordapp.com/attachments/1212641663122538537/1212641663780917349/3343C9C8-7DC3-4D8F-8BDC-FEA30BD5559C.jpg?ex=69fb82ce&is=69fa314e&hm=a61fe344d24c881b799d18efd6b36bb4c69a97557711bafb96bd89f217c6b501&"}], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": "1212641663122538537", "flags": 0, "thread_title": "简评海归线密契以及再演化密契", "forum_channel_id": "1174179624096378930", "is_thread_starter": true, "thread_tags": ["1174179716706619494"]}
