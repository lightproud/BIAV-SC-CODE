{"id": "1369542550557429893", "channel_id": "1300659495550062592", "type": 0, "author_id": "1359562716141846879", "author_name": "jovial_courgette_59416_16914", "author_bot": false, "content": "카오스 : 노디라 23 / 깊은바다 : 케이크스 / 혈육 : 테이스 살바도르 / 초차원 : 클레멘틴 다프다일 키울 예정인데", "timestamp": "2025-05-07T05:13:08.923000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
