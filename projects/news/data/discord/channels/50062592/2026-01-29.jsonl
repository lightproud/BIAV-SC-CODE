{"id": "1466297718065463351", "channel_id": "1300659495550062592", "type": 19, "author_id": "595478768659988490", "author_name": "aweonyu", "author_bot": false, "content": "유물?이랑 룬?은 머쓰나요?", "timestamp": "2026-01-29T05:03:38.481000+00:00", "edited_timestamp": null, "pinned": false, "mentions": ["256852230685196288"], "reactions": [], "attachments": [], "embeds": [], "reply_to": "1466297538222096465", "has_thread": false, "thread_id": null, "flags": 0}
