{"id": "1405748140631392266", "channel_id": "1377478664609857647", "type": 0, "author_id": "279045292639387648", "author_name": "horydragon", "author_bot": false, "content": "激しめかな？プレイスタイルによっては多少カバーできそうかもだけど、明らかに使いやすいのと難しいのは分かれてる気がする", "timestamp": "2025-08-15T03:01:14.264000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [{"emoji": "👍", "emoji_id": null, "count": 2}], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
