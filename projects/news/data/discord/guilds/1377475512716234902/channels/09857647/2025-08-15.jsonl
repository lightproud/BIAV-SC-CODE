{"id": "1405810653763076179", "channel_id": "1377478664609857647", "type": 0, "author_id": "1396445222107484160", "author_name": "demondontcry1275", "author_bot": false, "content": "バトルも楽しみだけど一番の楽しみはストーリー.....どんなストーリーでどんな展開なのかすごく楽しみです！", "timestamp": "2025-08-15T07:09:38.556000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [{"emoji": "👈", "emoji_id": null, "count": 2}, {"emoji": "👍", "emoji_id": null, "count": 1}], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
