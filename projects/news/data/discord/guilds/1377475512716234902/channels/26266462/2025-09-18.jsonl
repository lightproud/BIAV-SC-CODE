{"id": "1418057722984923258", "channel_id": "1400058619726266462", "type": 0, "author_id": "438289046993633281", "author_name": "iihige", "author_bot": false, "content": "1\n初手で集結、手札にカーシアの取り出しがある場合はカーシアで取り出す\nない場合は黒渦で取り出す", "timestamp": "2025-09-18T02:15:07.398000+00:00", "edited_timestamp": "2025-09-18T02:15:32.645000+00:00", "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
