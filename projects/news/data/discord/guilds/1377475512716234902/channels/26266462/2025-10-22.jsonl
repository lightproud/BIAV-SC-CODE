{"id": "1430345128878276660", "channel_id": "1400058619726266462", "type": 0, "author_id": "261538986340646924", "author_name": "typegreatdane", "author_bot": false, "content": "ナウティラ入れてるのでそちらに持たせてます　完凸するなら確かにリリーも良さそう", "timestamp": "2025-10-22T00:00:53.252000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
