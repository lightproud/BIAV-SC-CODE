{"id": "1423517564537016381", "channel_id": "1400058619726266462", "type": 0, "author_id": "1290697496036638800", "author_name": "stalk3r_0w0", "author_bot": false, "content": "リリーちゃんのモチーフ引くべきですかね？", "timestamp": "2025-10-03T03:50:35.063000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
