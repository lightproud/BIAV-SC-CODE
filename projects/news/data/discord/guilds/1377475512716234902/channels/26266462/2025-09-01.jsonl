{"id": "1412143132128051281", "channel_id": "1400058619726266462", "type": 0, "author_id": "544012464342302721", "author_name": "96cat", "author_bot": false, "content": "ガチャとか指定した札もらえるやつとかです", "timestamp": "2025-09-01T18:32:39.050000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
