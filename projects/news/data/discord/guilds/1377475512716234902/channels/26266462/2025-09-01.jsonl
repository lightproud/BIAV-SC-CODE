{"id": "1412125766933676096", "channel_id": "1400058619726266462", "type": 0, "author_id": "544012464342302721", "author_name": "96cat", "author_bot": false, "content": "恒常札で記憶螺旋以外に取るべき札ってあります？", "timestamp": "2025-09-01T17:23:38.865000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
