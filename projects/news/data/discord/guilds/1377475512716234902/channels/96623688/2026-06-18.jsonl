{"id": "1517129895325601933", "channel_id": "1391701560496623688", "type": 0, "author_id": "1510664172277469277", "author_name": "gupito0000", "author_bot": false, "content": "アドバイスのおかげで４章クリアできました😭沙耶ちゃん来たので強い編成教えてください！魔封便３つと輪転の書１つあります！", "timestamp": "2026-06-18T11:32:33.956000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [{"id": "1517129893375246406", "filename": "Screenshot_20260618-200233.png", "content_type": "image/png", "size": 2209537, "url": "https://cdn.discordapp.com/attachments/1391701560496623688/1517129893375246406/Screenshot_20260618-200233.png?ex=6a3528d1&is=6a33d751&hm=106991d6fd6be5ff1de080b4cf047626179d0bed65263af6795c6609edb353c7&"}, {"id": "1517129894016979024", "filename": "Screenshot_20260618-200248.png", "content_type": "image/png", "size": 2311184, "url": "https://cdn.discordapp.com/attachments/1391701560496623688/1517129894016979024/Screenshot_20260618-200248.png?ex=6a3528d1&is=6a33d751&hm=8444ec183fef6b76423ebcf76bd52300cf4b07e2d896d4367688caa1a76ed542&"}, {"id": "1517129894633672855", "filename": "Screenshot_20260618-200243.png", "content_type": "image/png", "size": 2297762, "url": "https://cdn.discordapp.com/attachments/1391701560496623688/1517129894633672855/Screenshot_20260618-200243.png?ex=6a3528d1&is=6a33d751&hm=ef62138c9946a2e4ef93bd760d5d483759bb9a1979a3e3918b6eeefc423ed8f9&"}], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
