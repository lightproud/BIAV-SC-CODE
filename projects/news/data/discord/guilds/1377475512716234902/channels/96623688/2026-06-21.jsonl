{"id": "1518043337788100670", "channel_id": "1391701560496623688", "type": 0, "author_id": "698695537951768578", "author_name": "ropchan", "author_bot": false, "content": "↑まじか　自分も気になります\n融災全然パーティ組めなくて困ってるけど極限サルバだけはいます", "timestamp": "2026-06-21T00:02:15.610000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
