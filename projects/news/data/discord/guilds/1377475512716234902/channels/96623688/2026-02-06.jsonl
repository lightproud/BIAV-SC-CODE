{"id": "1469479316307050516", "channel_id": "1391701560496623688", "type": 0, "author_id": "1450570668142891163", "author_name": "yuu_0o0", "author_bot": false, "content": "スマホを付けたときと、スマホで漫画読んでるときに起こりました。", "timestamp": "2026-02-06T23:46:10.613000+00:00", "edited_timestamp": null, "pinned": false, "mentions": [], "reactions": [], "attachments": [], "embeds": [], "reply_to": null, "has_thread": false, "thread_id": null, "flags": 0}
