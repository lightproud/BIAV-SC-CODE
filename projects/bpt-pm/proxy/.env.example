# BPT PM 本地 Notion 代理配置。复制本文件为 .env 并填写。.env 已被 .gitignore 挡在仓库外。

# Notion 内部集成令牌（secret_xxx）。在 https://www.notion.so/my-integrations 新建「内部集成」，
# 然后把目标数据库页面「···→ 连接 →（你的集成）」共享给它，令牌才能读写该库。
# 令牌是密钥：只放这里，绝不进浏览器 / 仓库 / 聊天。
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 目标数据库 ID（32 位十六进制，可含或不含短横）。
# 试跑库示例：dbcfca53752d4ba79d59724e4ff0176a
NOTION_DATABASE_ID=dbcfca53752d4ba79d59724e4ff0176a

# 代理端口（网页里填 http://localhost:<PORT>）。
PORT=8787

# —— 项目级排期配置（Notion 单行任务放不下，在此注入）——
PROJECT_NAME=Notion 排期
# 项目锚点开始日期（ISO）。排期从此日的第一个工作日起算。
PROJECT_START=2026-07-06
# 工作日：ISO 星期号，逗号分隔（1=周一 … 7=周日）。缺省周一至周五。
PROJECT_WORKDAYS=1,2,3,4,5
# 节假日例外：ISO 日期，逗号分隔。可留空。
PROJECT_HOLIDAYS=2026-07-20
