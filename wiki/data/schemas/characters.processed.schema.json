{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Morimens processed characters baseline (W2)",
  "description": "现行可信基线 projects/wiki/data/processed/characters.json 的形态锁定（2026-07-02）：顶层 {_meta, characters[]}，一手解包（AwakerConfig.lua 运行时提取）、无合成占位，category 经守密人 2026-06-16 多维证据法逐一裁定。旧 data/db/ 链 schema（characters.schema.json 等）随 2026-06-15 整层清空裁定成为遗留注册项，与本 schema 无关。",
  "type": "object",
  "required": ["_meta", "characters"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["source", "total_characters", "generated"],
      "properties": {
        "source": { "type": "string" },
        "total_characters": { "type": "integer", "minimum": 1 },
        "generated": { "type": "string" },
        "category_criterion": { "type": "string" },
        "category_counts": { "type": "object" }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "playable_evidence"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "gender": { "type": "string" },
          "birthday": { "type": "string" },
          "height": { "type": "string" },
          "weight": { "type": "string" },
          "gi": { "type": "string" },
          "voice_actor": { "type": "string" },
          "painter": { "type": "string" },
          "characteristic": { "type": "string" },
          "introduction": { "type": "string" },
          "gameplay_intro": { "type": "string" },
          "summon_slogan": { "type": "string" },
          "category": { "enum": ["playable", "unreleased", "easter_egg"] },
          "playable_evidence": { "type": "array", "items": { "type": "string" } },
          "confirmed_by": { "type": "string" },
          "variant_of_name_prefix": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  }
}
